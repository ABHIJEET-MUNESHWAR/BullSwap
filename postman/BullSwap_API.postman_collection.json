{
	"info": {
		"_postman_id": "bullswap-collection-v1",
		"name": "BullSwap API",
		"description": "BullSwap — A batch auction-based decentralized exchange aggregator built in Rust.\n\nBase URL: http://localhost:8080\n\nThis collection covers all REST API endpoints for orders, batches, settlements, tokens, and health checks.\n\n## Getting Started\n1. Start the server: `cargo run` or `docker compose up -d`\n2. Import this collection into Postman\n3. Set the `base_url` variable if not using localhost:8080\n4. Run the \"Health Check\" request first to verify connectivity\n5. Use the \"List Tokens\" request to get seed token IDs\n6. Create orders using the seeded ETH and USDC token IDs",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "eth_token_id",
			"value": "a0000000-0000-0000-0000-000000000001",
			"type": "string",
			"description": "Seeded ETH token UUID"
		},
		{
			"key": "usdc_token_id",
			"value": "a0000000-0000-0000-0000-000000000002",
			"type": "string",
			"description": "Seeded USDC token UUID"
		},
		{
			"key": "dai_token_id",
			"value": "a0000000-0000-0000-0000-000000000003",
			"type": "string",
			"description": "Seeded DAI token UUID"
		},
		{
			"key": "wbtc_token_id",
			"value": "a0000000-0000-0000-0000-000000000004",
			"type": "string",
			"description": "Seeded WBTC token UUID"
		},
		{
			"key": "order_uid",
			"value": "",
			"type": "string",
			"description": "Auto-populated after creating an order"
		},
		{
			"key": "batch_id",
			"value": "",
			"type": "string",
			"description": "Auto-populated after listing batches"
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has status ok', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql('ok');",
									"    pm.expect(jsonData.database).to.eql('connected');",
									"});",
									"",
									"pm.test('Response has version', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.version).to.be.a('string');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Check server and database health.\n\nReturns 200 if healthy, 503 if database is unreachable."
					},
					"response": []
				}
			],
			"description": "Server health and readiness checks."
		},
		{
			"name": "Tokens",
			"item": [
				{
					"name": "List Tokens",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test('Seeded tokens exist', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.length).to.be.at.least(5);",
									"    var symbols = jsonData.map(t => t.symbol);",
									"    pm.expect(symbols).to.include('ETH');",
									"    pm.expect(symbols).to.include('USDC');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/tokens",
							"host": ["{{base_url}}"],
							"path": ["v1", "tokens"]
						},
						"description": "List all registered tokens.\n\nThe database is seeded with ETH, USDC, DAI, WBTC, and USDT on startup."
					},
					"response": []
				},
				{
					"name": "Create Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Token has required fields', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.id).to.be.a('string');",
									"    pm.expect(jsonData.symbol).to.eql('LINK');",
									"    pm.expect(jsonData.name).to.eql('Chainlink');",
									"    pm.expect(jsonData.decimals).to.eql(18);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"symbol\": \"LINK\",\n    \"name\": \"Chainlink\",\n    \"decimals\": 18,\n    \"address\": \"0x514910771AF9Ca656af840dff83E8264EcF986CA\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/tokens",
							"host": ["{{base_url}}"],
							"path": ["v1", "tokens"]
						},
						"description": "Register a new token.\n\nThe `address` field must be unique across all tokens."
					},
					"response": []
				}
			],
			"description": "Token whitelist management."
		},
		{
			"name": "Orders",
			"item": [
				{
					"name": "Create Order — Sell ETH for USDC",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Order has required fields', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.uid).to.be.a('string');",
									"    pm.expect(jsonData.owner).to.eql('0xAlice');",
									"    pm.expect(jsonData.status).to.eql('open');",
									"    pm.expect(jsonData.batch_id).to.be.null;",
									"});",
									"",
									"// Save order UID for later requests",
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('order_uid', jsonData.uid);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"owner\": \"0xAlice\",\n    \"sell_token\": \"{{eth_token_id}}\",\n    \"buy_token\": \"{{usdc_token_id}}\",\n    \"sell_amount\": \"1.5\",\n    \"buy_amount\": \"3000\",\n    \"kind\": \"Sell\",\n    \"signature\": \"0xabcdef1234567890\",\n    \"valid_to\": \"2026-12-31T23:59:59Z\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/orders",
							"host": ["{{base_url}}"],
							"path": ["v1", "orders"]
						},
						"description": "Submit a new order to sell 1.5 ETH for at least 3000 USDC.\n\nThe order UID is auto-saved to the `order_uid` variable for subsequent requests."
					},
					"response": []
				},
				{
					"name": "Create Order — Buy ETH with USDC (Counter-order)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Order is open', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql('open');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"owner\": \"0xBob\",\n    \"sell_token\": \"{{usdc_token_id}}\",\n    \"buy_token\": \"{{eth_token_id}}\",\n    \"sell_amount\": \"3200\",\n    \"buy_amount\": \"1.5\",\n    \"kind\": \"Buy\",\n    \"signature\": \"0x9876543210fedcba\",\n    \"valid_to\": \"2026-12-31T23:59:59Z\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/orders",
							"host": ["{{base_url}}"],
							"path": ["v1", "orders"]
						},
						"description": "Submit a counter-order: Bob wants to buy 1.5 ETH with up to 3200 USDC.\n\nThis order overlaps with Alice's sell order, enabling a CoW (Coincidence of Wants) match in the next batch."
					},
					"response": []
				},
