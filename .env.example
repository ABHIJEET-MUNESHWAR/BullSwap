# BullSwap Configuration
# Copy this to .env and fill in your values

# PostgreSQL connection string (required)
DATABASE_URL=postgres://bullswap:bullswap@localhost:5432/bullswap

# Server configuration
HOST=127.0.0.1
PORT=8080

# Batch auction interval in seconds
BATCH_INTERVAL_SECS=30

# Logging level (trace, debug, info, warn, error)
LOG_LEVEL=info

# Optional API key for authenticated endpoints
# API_KEY=your-secret-api-key

# Maximum orders per batch
MAX_ORDERS_PER_BATCH=1000

# Number of threads for parallel solver execution
# Defaults to the number of CPU cores
# SOLVER_THREADS=8

